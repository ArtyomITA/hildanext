*.pb
*.mlpackage
*.mlmodel
*.lfs
# Cartelle modelli
hildanext/models/
models/


# =============================================================================
# [DATASET / DATI GREZZI / FILE GRANDI]
# Dati Dolma, Parquet, Arrow, HDF5 e simili non appartengono al VCS
# =============================================================================
hildanext/data/
# Formati dati pesanti (in qualsiasi cartella)
*.parquet
*.arrow
*.feather
*.hdf5
*.h5
*.npy
*.npz
*.pkl
*.pickle
*.msgpack
*.jsonl.gz
*.txt.gz
*.zst
# Archivi
*.tar
*.tar.gz
*.tar.bz2
*.tar.xz
*.zip
*.7z
*.rar


# =============================================================================
# [ARTEFATTI DI ESECUZIONE — runs/, logs, cache]
# Output di training, eval, cache temporanea
# =============================================================================
hildanext/runs/
hildanext/logs/
hildanext/cpt/
hildanext/reports/
# Log files individuali
hildanext/*.log
hildanext/cpt_run.log
# JSONL di training / eval (dati generati, non codice)
hildanext/*.jsonl
hildanext/*.summary.json
# Documenti HTML generati nella /docs (paper convertiti)
hildanext/docs/*.html
hildanext/docs/reports/
# PDF di paper
hildanext/*.pdf
hildanext/llada21_extracted/
hildanext/llada21_extracted.txt
# Tensorboard / wandb
wandb/
lightning_logs/
*.tfevents.*


